# ============================================================
# WAIQ Radar - Variables de entorno
# Copia este archivo como .env y rellena los valores
# ============================================================

# --- LLM API Key (elige uno según config.yaml llm.provider) ---
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AI...

# --- Search API Key (elige uno según config.yaml search.provider) ---
SERPER_API_KEY=...
# TAVILY_API_KEY=tvly-...
# SEARXNG_URL=http://localhost:8080

# --- Email SMTP ---
SMTP_USERNAME=tu@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- GitHub (solo si github.enabled = true) ---
GITHUB_TOKEN=ghp_...
